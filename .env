# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5433

# User Service
USER_SERVICE_PORT=8000
USER_SERVICE_DB_NAME=user_db

# Cargo Service
CARGO_SERVICE_PORT=8001
CARGO_SERVICE_DB_NAME=cargo_db

# Route Service
ROUTE_SERVICE_PORT=8002
ROUTE_SERVICE_DB_NAME=route_db

# Order Service
ORDER_SERVICE_PORT=8003
ORDER_SERVICE_DB_NAME=order_db

# Gateway
GATEWAY_PORT=8005

# JWT
JWT_SECRET=super-secret-key
JWT_EXPIRATION_HOURS=24

# URL внутренних сервисов (используются в Gateway)
USER_SERVICE_URL=http://localhost:8000
CARGO_SERVICE_URL=http://localhost:8001
ROUTE_SERVICE_URL=http://localhost:8002
ORDER_SERVICE_URL=http://localhost:8003

NOTIFICATION_SERVICE_PORT=8006
NOTIFICATION_SERVICE_DB_HOST=localhost
NOTIFICATION_SERVICE_DB_PORT=5432
NOTIFICATION_SERVICE_DB_USER=postgres
NOTIFICATION_SERVICE_DB_PASSWORD=postgres
NOTIFICATION_SERVICE_DB_NAME=notification_db